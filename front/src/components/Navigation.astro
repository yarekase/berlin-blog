---
/**
 * 導航欄組件
 */
---

<nav class="border-b border-white/10 bg-void-black sticky top-0 z-50">
  <div
    class="max-w-[1400px] mx-auto px-6 py-4 flex items-center justify-between"
  >
    <h1 class="text-xl font-bold">後台管理</h1>
    <div class="flex items-center gap-4">
      <button
        id="settingsBtn"
        class="px-4 py-2 text-sm font-medium text-slate-400 hover:text-primary transition-colors"
      >
        設定
      </button>
      <button
        id="logoutBtn"
        class="px-4 py-2 text-sm font-medium text-slate-400 hover:text-primary transition-colors"
      >
        登出
      </button>
    </div>
  </div>
</nav>

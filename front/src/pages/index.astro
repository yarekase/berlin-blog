---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Yoshua | 數位野獸派首頁">
	
	<section class="flex flex-col items-center justify-center min-h-screen px-4 text-center">
		
		<h1 class="text-6xl md:text-8xl font-black tracking-tighter text-slate-100 uppercase mb-4">
			Yoshua <br class="md:hidden" /> <span class="text-outline">Dev</span>
		</h1>
		
		<p class="text-xl md:text-2xl font-light tracking-[0.2em] text-slate-400 uppercase">
			Software Engineer in Progress / Kaohsiung
		</p>

		<div class="mt-12 w-full max-w-md px-4">
			<div class="flex justify-between mb-2 font-display text-xs tracking-widest uppercase">
        		<span class="text-stucco-white">Development Progress</span>
        		<span class="text-primary font-bold">5%</span>
    		</div>

    		<div class="h-4 w-full bg-void-black border border-stucco-white/20 overflow-hidden">
        
        		<div class="h-full bg-primary w-[5%] shadow-[0_0_15px_rgba(236,19,19,0.4)]"></div>
        
    		</div>
			<p class="mt-3 text-[10px] text-slate-500 uppercase tracking-tighter">
        		Current Stack: React / Node.js / Astro / SQL
    		</p>
		</div>


		<div class="w-20 h-1 bg-slate-100 mt-8 opacity-50"></div>

	</section>

</Layout>

<style>
	/* 這裡加一點點首頁專屬的特殊效果：空心字 */
	.text-outline {
		-webkit-text-stroke: 1px rgba(241, 245, 249, 0.5);
		color: transparent;
	}
</style>

---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="後台儀表板 - 子迂的蠹酸齋">
  <main class="min-h-screen bg-void-black text-stucco-white font-display pb-24">
    <!-- 頂部導航 -->
    <nav class="border-b border-white/10 bg-void-black sticky top-0 z-50">
      <div
        class="max-w-[1400px] mx-auto px-6 py-4 flex items-center justify-between"
      >
        <h1 class="text-xl font-bold">後台管理</h1>
        <div class="flex items-center gap-4">
          <button
            id="settingsBtn"
            class="px-4 py-2 text-sm font-medium text-slate-400 hover:text-primary transition-colors"
            >設定</button
          >
          <button
            id="logoutBtn"
            class="px-4 py-2 text-sm font-medium text-slate-400 hover:text-primary transition-colors"
            >登出</button
          >
        </div>
      </div>
    </nav>

    <!-- 主要內容 -->
    <div class="max-w-[1400px] mx-auto px-6 py-8">
      <!-- 儀表板統計 -->
      <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="border border-white/10 rounded-lg p-6 bg-void-black/50">
          <div class="text-slate-400 text-sm font-medium mb-2">發佈文章</div>
          <div class="text-4xl font-bold text-white" id="publishedCount">0</div>
        </div>
        <div class="border border-white/10 rounded-lg p-6 bg-void-black/50">
          <div class="text-slate-400 text-sm font-medium mb-2">草稿</div>
          <div class="text-4xl font-bold text-white" id="draftCount">0</div>
        </div>
        <div class="border border-white/10 rounded-lg p-6 bg-void-black/50">
          <div class="text-slate-400 text-sm font-medium mb-2">總文章數</div>
          <div class="text-4xl font-bold text-white" id="totalCount">0</div>
        </div>
      </section>

      <!-- 文章管理區 -->
      <section>
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-bold">文章管理</h2>
          <button
            id="newPostBtn"
            class="bg-primary text-white px-6 py-2 rounded font-bold hover:bg-primary/80 transition-all"
          >
            新增文章
          </button>
        </div>

        <!-- 文章列表 -->
        <div class="border border-white/10 rounded-lg overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-void-black/50 border-b border-white/10">
                <tr>
                  <th
                    class="px-6 py-4 text-left text-sm font-semibold text-slate-400"
                    >標題</th
                  >
                  <th
                    class="px-6 py-4 text-left text-sm font-semibold text-slate-400"
                    >分類</th
                  >
                  <th
                    class="px-6 py-4 text-left text-sm font-semibold text-slate-400"
                    >狀態</th
                  >
                  <th
                    class="px-6 py-4 text-left text-sm font-semibold text-slate-400"
                    >建立日期</th
                  >
                  <th
                    class="px-6 py-4 text-left text-sm font-semibold text-slate-400"
                    >操作</th
                  >
                </tr>
              </thead>
              <tbody id="postsList">
                <tr>
                  <td colspan="5" class="px-6 py-8 text-center text-slate-500">
                    暫無文章
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </div>
  </main>

  <!-- 編輯模態框 -->
  <div
    id="editModal"
    class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4"
  >
    <div
      class="bg-void-black border border-white/10 rounded-lg max-w-4xl w-full max-h-[90vh] overflow-y-auto"
    >
      <div
        class="sticky top-0 bg-void-black border-b border-white/10 px-6 py-4 flex items-center justify-between"
      >
        <h3 class="text-xl font-bold" id="modalTitle">新增文章</h3>
        <button
          id="closeModalBtn"
          class="text-slate-400 hover:text-white transition-colors"
        >
          ✕
        </button>
      </div>

      <form id="postForm" class="p-6 space-y-6">
        <div>
          <label
            for="title"
            class="block text-sm font-medium text-slate-400 mb-2"
            >文章標題</label
          >
          <input
            type="text"
            id="title"
            name="title"
            class="w-full px-4 py-2 bg-void-black border border-white/20 rounded text-white focus:outline-none focus:border-primary transition-colors"
            required
          />
        </div>

        <div>
          <label
            for="category"
            class="block text-sm font-medium text-slate-400 mb-2">分類</label
          >
          <select
            id="category"
            name="category"
            class="w-full px-4 py-2 bg-void-black border border-white/20 rounded text-white focus:outline-none focus:border-primary transition-colors"
            required
          >
            <option value="">選擇分類</option>
            <option value="coding">Coding</option>
            <option value="finance">Finance</option>
            <option value="design">Design</option>
            <option value="kaohsiung">Kaohsiung</option>
            <option value="life">Life</option>
          </select>
        </div>

        <div>
          <label
            for="excerpt"
            class="block text-sm font-medium text-slate-400 mb-2">摘要</label
          >
          <textarea
            id="excerpt"
            name="excerpt"
            rows="3"
            class="w-full px-4 py-2 bg-void-black border border-white/20 rounded text-white focus:outline-none focus:border-primary transition-colors"
          ></textarea>
        </div>

        <div>
          <label
            for="content"
            class="block text-sm font-medium text-slate-400 mb-2">內容</label
          >
          <div
            id="editorjs"
            class="min-h-[400px] border border-white/20 rounded p-4 bg-void-black text-white"
          >
          </div>
          <textarea id="content" name="content" class="hidden"></textarea>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label
              for="status"
              class="block text-sm font-medium text-slate-400 mb-2">狀態</label
            >
            <select
              id="status"
              name="status"
              class="w-full px-4 py-2 bg-void-black border border-white/20 rounded text-white focus:outline-none focus:border-primary transition-colors"
            >
              <option value="draft">草稿</option>
              <option value="published">發佈</option>
            </select>
          </div>
          <div>
            <label
              for="publishedAt"
              class="block text-sm font-medium text-slate-400 mb-2"
              >發佈日期</label
            >
            <input
              type="datetime-local"
              id="publishedAt"
              name="publishedAt"
              class="w-full px-4 py-2 bg-void-black border border-white/20 rounded text-white focus:outline-none focus:border-primary transition-colors"
            />
          </div>
        </div>

        <div class="flex gap-4 pt-4">
          <button
            type="submit"
            id="submitBtn"
            class="flex-1 bg-primary text-white px-6 py-2 rounded font-bold hover:bg-primary/80 transition-all"
          >
            保存
          </button>
          <button
            type="button"
            class="flex-1 bg-void-black border border-white/20 text-white px-6 py-2 rounded font-bold hover:border-white/40 transition-all"
            onclick="document.getElementById('editModal').classList.add('hidden')"
          >
            取消
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- 設定模態框 -->
  <div
    id="settingsModal"
    class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4"
  >
    <div
      class="bg-void-black border border-white/10 rounded-lg max-w-md w-full"
    >
      <div
        class="px-6 py-4 border-b border-white/10 flex items-center justify-between"
      >
        <h3 class="text-xl font-bold">設定</h3>
        <button
          id="closeSettingsBtn"
          class="text-slate-400 hover:text-white transition-colors"
        >
          ✕
        </button>
      </div>

      <form id="settingsForm" class="p-6 space-y-6">
        <div>
          <label
            for="nickname"
            class="block text-sm font-medium text-slate-400 mb-2">暱稱</label
          >
          <input
            type="text"
            id="nickname"
            name="nickname"
            class="w-full px-4 py-2 bg-void-black border border-white/20 rounded text-white focus:outline-none focus:border-primary transition-colors"
            placeholder="輸入您的暱稱"
          />
        </div>

        <div class="flex gap-4 pt-4">
          <button
            type="submit"
            class="flex-1 bg-primary text-white px-6 py-2 rounded font-bold hover:bg-primary/80 transition-all"
          >
            保存
          </button>
          <button
            type="button"
            class="flex-1 bg-void-black border border-white/20 text-white px-6 py-2 rounded font-bold hover:border-white/40 transition-all"
            onclick="document.getElementById('settingsModal').classList.add('hidden')"
          >
            取消
          </button>
        </div>
      </form>
    </div>
  </div>
</Layout>

<script>
  // 1. 使用 D1 資料庫完全同步的介面
  import type { Category, Post } from "../../types/interfaces";

  // 2. 全域變數與狀態
  let editor: any = null; // Editor.js 編輯器物件
  let posts: Post[] = [];
  // 模擬從 D1 抓取的分類清單
  const allCategories: Category[] = [
    { id: 1, name: "軟體工程", slug: "coding", sort_order: 1 },
    { id: 2, name: "生活隨筆", slug: "life", sort_order: 2 },
    { id: 3, name: "金融投資", slug: "finance", sort_order: 3 },
    { id: 4, name: "高雄在地", slug: "kaohsiung", sort_order: 4 },
  ];

  // 3. 輔助函式

  // declare global 讓 TypeScript 知道我要修改全域的物件
  declare global {
    // 針對window物件新增兩個方法，分別是editPost和deletePost，這樣在其他地方就可以直接呼叫
    interface Window {
      editPost: (index: number) => void;
      deletePost: (index: number) => void;
    }
  }
</script>

<style>
  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--color-primary);
  }

  /* Editor.js 暗色主題 */
  .codex-editor {
    color: white;
  }

  .codex-editor__redactor {
    padding-bottom: 100px !important;
  }

  .ce-block__content,
  .ce-toolbar__content {
    max-width: none;
  }

  .ce-paragraph[data-placeholder]:empty::before {
    color: #9ca3af;
  }

  .ce-header {
    color: white;
  }

  .ce-toolbar__plus,
  .ce-toolbar__settings-btn {
    color: white;
  }

  .ce-toolbox {
    background: #1f2937;
    border: 1px solid #374151;
  }

  .ce-toolbox__toggler {
    color: white;
  }

  .ce-block--selected .ce-block__content {
    background-color: rgba(59, 130, 246, 0.1);
  }

  .ce-inline-toolbar {
    background: #1f2937;
    border: 1px solid #374151;
  }

  .ce-inline-toolbar__buttons {
    color: white;
  }

  .ce-conversion-toolbar {
    background: #1f2937;
    border: 1px solid #374151;
  }

  .ce-conversion-toolbar__buttons {
    color: white;
  }
</style>

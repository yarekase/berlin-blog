---
/**
 * 後台儀表板主頁面
 * 這是經過重構的主頁面，使用了模塊化組件
 */
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.astro";
import Statistics from "../../components/Statistics.astro";
import PostsList from "../../components/PostsList.astro";
import EditModal from "../../components/EditModal.astro";
import SettingsModal from "../../components/SettingsModal.astro";
import "../../styles/editor.css";
---

<Layout title="後台儀表板 - 子迂的蠹酸齋">
  <main class="min-h-screen bg-void-black text-stucco-white font-display pb-24">
    <!-- 導航欄 -->
    <Navigation />

    <!-- 主要內容 -->
    <div class="max-w-[1400px] mx-auto px-6 py-8">
      <!-- 儀表板統計 -->
      <Statistics />

      <!-- 文章管理區 -->
      <PostsList />
    </div>
  </main>

  <!-- 編輯模態框 -->
  <EditModal />

  <!-- 設定模態框 -->
  <SettingsModal />
</Layout>

<script>
  import {
    checkAuth,
    logout,
    setNickname,
    getNickname,
  } from "../../utils/auth";
  import { postManager, type Post } from "../../utils/postManager";
  import {
    initEditor,
    saveEditorContent,
    destroyEditor,
  } from "../../utils/editorManager";

  // ===== 全局變數 - 外層作用域 =====
  let editModal: HTMLDivElement | null = null;
  let settingsModal: HTMLDivElement | null = null;

  // ===== 渲染函數 =====
  function renderPosts() {
    const postsList = document.getElementById(
      "postsList",
    ) as HTMLTableSectionElement | null;
    const publishedCount = document.getElementById(
      "publishedCount",
    ) as HTMLDivElement | null;
    const draftCount = document.getElementById(
      "draftCount",
    ) as HTMLDivElement | null;
    const totalCount = document.getElementById(
      "totalCount",
    ) as HTMLDivElement | null;

    if (!postsList) return;

    const posts = postManager.getPosts();

    if (posts.length === 0) {
      postsList.innerHTML =
        '<tr><td colspan="6" class="px-6 py-8 text-center text-slate-500">暫無文章</td></tr>';
    } else {
      postsList.innerHTML = posts
        .map(
          (post) => `
        <tr class="border-t border-white/10 hover:bg-void-black/50 transition-colors">
          <td class="px-6 py-4 text-white">${post.title}</td>
          <td class="px-6 py-4 text-slate-400 text-sm">${post.author_name}</td>
          <td class="px-6 py-4 text-slate-400 text-sm">${post.categories.map((c) => c.name).join(", ")}</td>
          <td class="px-6 py-4">
            <span class="px-3 py-1 text-xs font-medium rounded ${
              post.status === "published"
                ? "bg-green-500/20 text-green-400"
                : "bg-yellow-500/20 text-yellow-400"
            }">
              ${post.status === "published" ? "發佈" : "草稿"}
            </span>
          </td>
          <td class="px-6 py-4 text-slate-400 text-sm">${new Date(post.created_at).toLocaleDateString()}</td>
          <td class="px-6 py-4 text-sm">
            <button class="text-primary hover:text-primary/80 transition-colors mr-4" onclick="editPost('${post.id}')">編輯</button>
            <button class="text-red-500 hover:text-red-400 transition-colors" onclick="deletePost('${post.id}')">刪除</button>
          </td>
        </tr>
      `,
        )
        .join("");
    }

    // 更新統計
    if (publishedCount)
      publishedCount.textContent = postManager.getPublishedCount().toString();
    if (draftCount)
      draftCount.textContent = postManager.getDraftCount().toString();
    if (totalCount)
      totalCount.textContent = postManager.getTotalCount().toString();
  }

  // ===== 全局函數 - 供 onclick 事件調用 =====
  function deletePost(id: string) {
    if (confirm("確定要刪除嗎？")) {
      if (postManager.deletePost(id)) {
        renderPosts();
      }
    }
  }

  async function editPost(id: string) {
    const post = postManager.getPost(id);
    if (!post) return;

    const titleInput = document.getElementById(
      "title",
    ) as HTMLInputElement | null;
    const authorNameInput = document.getElementById(
      "author_name",
    ) as HTMLInputElement | null;
    const slugInput = document.getElementById(
      "slug",
    ) as HTMLInputElement | null;
    const summaryTextarea = document.getElementById(
      "summary",
    ) as HTMLTextAreaElement | null;
    const coverImageInput = document.getElementById(
      "cover_image",
    ) as HTMLInputElement | null;
    const statusSelect = document.getElementById(
      "status",
    ) as HTMLSelectElement | null;
    const modalTitle = document.getElementById(
      "modalTitle",
    ) as HTMLHeadingElement | null;
    const submitBtn = document.getElementById(
      "submitBtn",
    ) as HTMLButtonElement | null;
    const postForm = document.getElementById(
      "postForm",
    ) as HTMLFormElement | null;
    const categoriesContainer = document.getElementById(
      "categoriesContainer",
    ) as HTMLDivElement | null;

    if (
      !titleInput ||
      !authorNameInput ||
      !slugInput ||
      !summaryTextarea ||
      !coverImageInput ||
      !statusSelect ||
      !modalTitle ||
      !submitBtn ||
      !postForm ||
      !editModal ||
      !categoriesContainer
    )
      return;

    // 填充表單
    titleInput.value = post.title;
    authorNameInput.value = post.author_name;
    slugInput.value = post.slug;
    summaryTextarea.value = post.summary || "";
    coverImageInput.value = post.cover_image;
    statusSelect.value = post.status;

    // 生成分類選項
    const categories = postManager.getCategories();
    categoriesContainer.innerHTML = categories
      .map(
        (category) => `
        <label class="flex items-center">
          <input
            type="checkbox"
            value="${category.id}"
            class="mr-2"
            ${post.categories.some((c) => c.id === category.id) ? "checked" : ""}
          />
          ${category.name}
        </label>
      `,
      )
      .join("");

    // 初始化 Editor.js 並載入內容
    const editorData = post.content ? JSON.parse(post.content) : null;
    await initEditor(editorData);

    modalTitle.textContent = "編輯文章";
    submitBtn.textContent = "更新";

    postForm.onsubmit = async (e: Event) => {
      e.preventDefault();
      const contentData = await saveEditorContent();

      // 獲取選中的分類
      const selectedCategoryIds = Array.from(
        categoriesContainer.querySelectorAll('input[type="checkbox"]:checked'),
      ).map((checkbox) => parseInt((checkbox as HTMLInputElement).value));
      const selectedCategories = categories.filter((c) =>
        selectedCategoryIds.includes(c.id),
      );

      postManager.updatePost(id, {
        title: titleInput.value,
        author_name: authorNameInput.value,
        content: JSON.stringify(contentData),
        summary: summaryTextarea.value || undefined,
        cover_image: coverImageInput.value,
        status: statusSelect.value as "draft" | "published",
        categories: selectedCategories,
      });

      renderPosts();
      await destroyEditor();
      editModal.classList.add("hidden");
    };

    editModal.classList.remove("hidden");
  }

  // ===== 頁面初始化 - DOMContentLoaded =====
  document.addEventListener("DOMContentLoaded", () => {
    // 認證檢查
    checkAuth();

    // 取得模態框和按鈕元素
    editModal = document.getElementById("editModal") as HTMLDivElement | null;
    settingsModal = document.getElementById(
      "settingsModal",
    ) as HTMLDivElement | null;
    const newPostBtn = document.getElementById(
      "newPostBtn",
    ) as HTMLButtonElement | null;
    const settingsBtn = document.getElementById(
      "settingsBtn",
    ) as HTMLButtonElement | null;
    const closeModalBtn = document.getElementById(
      "closeModalBtn",
    ) as HTMLButtonElement | null;
    const closeSettingsBtn = document.getElementById(
      "closeSettingsBtn",
    ) as HTMLButtonElement | null;
    const logoutBtn = document.getElementById(
      "logoutBtn",
    ) as HTMLButtonElement | null;
    const settingsForm = document.getElementById(
      "settingsForm",
    ) as HTMLFormElement | null;
    const postForm = document.getElementById(
      "postForm",
    ) as HTMLFormElement | null;

    if (
      !editModal ||
      !settingsModal ||
      !newPostBtn ||
      !settingsBtn ||
      !closeModalBtn ||
      !closeSettingsBtn
    ) {
      console.error("必要的 DOM 元素未找到");
      return;
    }

    // ===== 新增文章 =====
    newPostBtn.addEventListener("click", () => {
      const modalTitle = document.getElementById(
        "modalTitle",
      ) as HTMLHeadingElement | null;
      const submitBtn = document.getElementById(
        "submitBtn",
      ) as HTMLButtonElement | null;
      const categoriesContainer = document.getElementById(
        "categoriesContainer",
      ) as HTMLDivElement | null;
      if (postForm && modalTitle && submitBtn && categoriesContainer) {
        postForm.reset();
        modalTitle.textContent = "新增文章";
        submitBtn.textContent = "新增";

        // 生成分類選項
        const categories = postManager.getCategories();
        categoriesContainer.innerHTML = categories
          .map(
            (category) => `
            <label class="flex items-center">
              <input type="checkbox" value="${category.id}" class="mr-2" />
              ${category.name}
            </label>
          `,
          )
          .join("");

        initEditor();
        editModal.classList.remove("hidden");

        // 重新綁定 submit 事件用於新增
        postForm.onsubmit = async (e: Event) => {
          e.preventDefault();
          const contentData = await saveEditorContent();

          const titleInput = document.getElementById(
            "title",
          ) as HTMLInputElement | null;
          const authorNameInput = document.getElementById(
            "author_name",
          ) as HTMLInputElement | null;
          const slugInput = document.getElementById(
            "slug",
          ) as HTMLInputElement | null;
          const summaryTextarea = document.getElementById(
            "summary",
          ) as HTMLTextAreaElement | null;
          const coverImageInput = document.getElementById(
            "cover_image",
          ) as HTMLInputElement | null;
          const statusSelect = document.getElementById(
            "status",
          ) as HTMLSelectElement | null;
          const categoriesContainer = document.getElementById(
            "categoriesContainer",
          ) as HTMLDivElement | null;

          if (
            !titleInput ||
            !authorNameInput ||
            !slugInput ||
            !summaryTextarea ||
            !coverImageInput ||
            !statusSelect ||
            !categoriesContainer
          )
            return;

          // 獲取選中的分類
          const selectedCategoryIds = Array.from(
            categoriesContainer.querySelectorAll(
              'input[type="checkbox"]:checked',
            ),
          ).map((checkbox) => parseInt((checkbox as HTMLInputElement).value));
          const selectedCategories = postManager
            .getCategories()
            .filter((c) => selectedCategoryIds.includes(c.id));

          postManager.addPost({
            title: titleInput.value,
            author_name: authorNameInput.value,
            content: JSON.stringify(contentData),
            cover_image: coverImageInput.value,
            status: statusSelect.value as "draft" | "published",
            categories: selectedCategories,
          });

          renderPosts();
          await destroyEditor();
          editModal.classList.add("hidden");
        };
      }
    });

    // ===== 設定按鈕 =====
    settingsBtn.addEventListener("click", () => {
      const nicknameInput = document.getElementById(
        "nickname",
      ) as HTMLInputElement | null;
      if (nicknameInput) {
        nicknameInput.value = getNickname();
        settingsModal.classList.remove("hidden");
      }
    });

    // ===== 關閉模態框 =====
    closeModalBtn.addEventListener("click", () => {
      editModal.classList.add("hidden");
      destroyEditor();
    });

    closeSettingsBtn.addEventListener("click", () => {
      settingsModal.classList.add("hidden");
    });

    // 點擊背景關閉模態框
    editModal.addEventListener("click", (e: Event) => {
      if (e.target === editModal) {
        editModal.classList.add("hidden");
        destroyEditor();
      }
    });

    settingsModal.addEventListener("click", (e: Event) => {
      if (e.target === settingsModal) {
        settingsModal.classList.add("hidden");
      }
    });

    // ===== Slug 自動生成 =====
    const titleInput = document.getElementById(
      "title",
    ) as HTMLInputElement | null;
    const slugInput = document.getElementById(
      "slug",
    ) as HTMLInputElement | null;
    if (titleInput && slugInput) {
      titleInput.addEventListener("input", () => {
        const slug = titleInput.value
          .toLowerCase()
          .replace(/[^\w\s-]/g, "")
          .replace(/[\s_-]+/g, "-")
          .replace(/^-+|-+$/g, "");
        slugInput.value = slug;
      });
    }

    // ===== 設定表單提交 =====
    if (settingsForm) {
      settingsForm.addEventListener("submit", (e: Event) => {
        e.preventDefault();
        const nicknameInput = document.getElementById(
          "nickname",
        ) as HTMLInputElement | null;
        if (nicknameInput) {
          setNickname(nicknameInput.value);
          settingsModal.classList.add("hidden");
          alert("設定已保存");
        }
      });
    }

    // ===== 登出 =====
    if (logoutBtn) {
      logoutBtn.addEventListener("click", () => {
        logout();
      });
    }

    // 初始化頁面
    renderPosts();
  });
</script>
